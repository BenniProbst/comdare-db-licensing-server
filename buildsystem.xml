<?xml version="1.0" encoding="UTF-8"?>
<!--
  comdare-db-licensing-server - DB-specific licensing server wrapper
  buildsystem.xml

  Schema: https://bep-venture.de/schemas/buildsystem v3.4.15
  Status: IMPLEMENTED (wraps comdare-licensing-server for DB context)
-->
<buildSystem version="3.4.15" xmlns="https://bep-venture.de/schemas/buildsystem">

  <project>
    <name>comdare-db-licensing-server</name>
    <version>0.1.0</version>
    <description>DB-specific wrapper around comdare-licensing-server. Integrates HA-PostgreSQL backend, cluster-aware license management, and DB-specific admin endpoints.</description>
    <type>module</type>
    <license>EULA</license>
    <maintainer>BEP Venture UG</maintainer>
    <repository>https://github.com/BenniProbst/comdare-db-licensing-server.git</repository>
  </project>

  <dependencies>
    <dependency name="cd-buildsystem-core" version="3.4.15" source="layer1" updatePolicy="stable" policy="require-failure" branch="development" />
    <dependency name="comdare-licensing-server" version="0.1.0" source="modules" updatePolicy="stable" policy="require-failure" branch="development" />
    <dependency name="comdare-db-licensing" version="0.1.0" source="products" updatePolicy="stable" policy="require-failure" branch="development" />
  </dependencies>

  <requiredModules>
    <module name="cd-buildsystem-core" version="3.4.15" updatePolicy="stable">
      <repo>BenniProbst/cd-buildsystem-core</repo>
      <branch>development</branch>
      <source>git</source>
    </module>
    <module name="comdare-licensing-server" version="0.1.0" updatePolicy="stable">
      <repo>BenniProbst/comdare-licensing-server</repo>
      <branch>development</branch>
      <source>git</source>
    </module>
  </requiredModules>

  <dimensions>
    <dimension id="D3" name="Build Modes" enabled="true" phase="2+">
      <include file="${COMDARE_BUILDSYSTEM_ROOT}/cookbooks/base.xml" />
    </dimension>
    <dimension id="D5" name="Build Configurations" enabled="true" />
  </dimensions>

  <build>
    <system>cmake</system>
    <targets>
      <target>comdare-db-licensing-server</target>
    </targets>
    <install>
      <headers>include</headers>
    </install>
  </build>

  <phases>
    <phase id="0" name="Bootstrap" interpreter="bash" enabled="true" />
    <phase id="1" name="GroundTruth" interpreter="bash" enabled="true" compilers="GCC,Clang" />
    <phase id="2" name="ProjectBuild" interpreter="cmake" enabled="true" />
    <phase id="3" name="TargetDelivery" interpreter="cpp" enabled="true" compilers="GCC,Clang,MSVC" />
    <phase id="4" name="HardwareAcceleration" interpreter="cpp" enabled="false" />
    <phase id="5" name="AIOptimization" interpreter="cpp" enabled="false" />
  </phases>

  <exports>
    <environment>
      <var name="COMDARE_DB_LICENSING_SERVER_ROOT" path="." />
    </environment>
  </exports>

</buildSystem>
